---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Now">
  <div class="section">
    <div class="container">
      <h1>Now</h1>
      <p class="updated">Last updated: February 2026</p>

      <div class="prose">
        <p>
          This is a <a href="https://nownownow.com/about" target="_blank" rel="noopener">now page</a>.
          It tells you what I'm up to at this point in my life.
        </p>

        <h2>Currently</h2>
        <ul>
          <li>Building this website</li>
          <li>Learning about astrophysical radiative processes</li>
          <li>Wrapping up two astro projects</li>
          <li>Reading Bury Our Bones in the Midnight Soil by V.E. Schwarb</li>
          <li>Listening to <a href="https://www.listentofeist.com/" target="_blank" rel="noopener">Multitude</a>, 
          <a href="https://www.dodie.co/" target="_blank" rel="noopener">Dodie</a>,
           <a href="https://open.spotify.com/artist/4I2BJf80C0skQpp1sQmA0h" target="_blank" rel="noopener">Belle and Sebastian</a>, 
           <a href="https://anginedepoitrine.com/" target="_blank" rel="noopener">Angine de Poitrine</a></li>
          <li>Getting back to running</li>
          <li>Thinking about what to do with my career</li>
        </ul>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .updated {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
</style>
