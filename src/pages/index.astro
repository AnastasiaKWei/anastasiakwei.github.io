---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Home" isHome={true}>
  <div class="home-overlay">
    <div class="home-content">
      <h1 class="hero-title">Anastasia Wei</h1>

      <div class="quick-links">
        <a href="/now" class="home-link">Now</a>
        <span class="link-sep">/</span>
        <a href="/projects" class="home-link">Projects</a>
        <span class="link-sep">/</span>
        <a href="/writing" class="home-link">Writing</a>
      </div>

      <p class="hero-subtitle">
        Tread lightly, but make a difference.<br/>
        <span class="quote-author">— Seth Godin</span>
      </p>

      <div class="hero-bio">
        <p>Hi, I'm Anastasia Wei. I'm an Astrophysics PhD student at UC Berkeley, where I build AI agents for automating science research workflows and discovering interesting targets in modern astronomical surveys.</p>
        <p>I care deeply about the future of humanity as we enter the age of transformative AI, and think carefully about the catastrophic and existential risks it could bring. Right now the window to get our decisions right feels rather narrow.</p>
        <p>I like meeting new people. If you happen to find yourself in Berkeley, feel free to reach out and we can go grab coffee. </p>
        <p class="bio-links">
          <a href="https://tally.so/r/VLVevJ" target="_blank" rel="noopener" class="more-link">Help me be a better person <span class="link-tag">[↗]</span></a>
          <span class="link-sep">/</span>
          <a href="https://tally.so/r/b5LpKo" target="_blank" rel="noopener" class="more-link">Submit a hot take <span class="link-tag">[↗]</span></a>
        </p>
      </div>

      <div class="more-sections">
        <details class="more-section">
          <summary>Contact</summary>
          <div class="section-body">
            <a href="mailto:astkwei@gmail.com" class="more-link contact-item"><Icon name="mdi:email-outline" class="contact-icon" /> astkwei@gmail.com</a><br/>
            <span class="contact-item"><Icon name="simple-icons:signal" class="contact-icon" /> astwei.11</span>
          </div>
        </details>


        <details class="more-section">
          <summary>More</summary>
          <div class="section-body">
            placehoder
          </div>
          <details class="more-section">
            <summary>More</summary>
            <div class="section-body">Placeholder.</div>
            <details class="more-section">
              <summary>More</summary>
              <div class="section-body">Placeholder.</div>
              <details class="more-section">
                <summary>More</summary>
                <div class="section-body">Placeholder.</div>
              </details>
            </details>
          </details>
        </details>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .home-overlay {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 0 3rem;
    padding-left: max(3rem, 8vw);
    pointer-events: none;
  }

  .home-overlay * {
    pointer-events: auto;
  }

  .home-content {
    max-width: 520px;
    font-family: 'Cormorant Garamond', Georgia, serif;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    letter-spacing: -0.03em;
    color: #ffffff;
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.5);
    line-height: 1.05;
  }

  .quick-links {
    margin-top: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .home-link {
    color: #ffffff;
    font-size: 1.15rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 700;
    transition: color 0.2s;
  }
  .home-link:hover {
    color: var(--accent);
  }

  .link-sep {
    color: rgba(255, 255, 255, 0.35);
    font-size: 1.1rem;
  }

  .hero-subtitle {
    margin-top: 1.2rem;
    font-size: 1rem;
    font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
    color: #ffffff;
    line-height: 1.7;
    max-width: 440px;
  }

  .hero-bio {
    margin-top: 1.4rem;
    font-size: 1rem;
    font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
    color: #ffffff;
    line-height: 1.7;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  :global([data-theme="light"]) .hero-bio {
    color: #3a2a18;
  }

  .quote-author {
    display: block;
    text-align: right;
    font-style: italic;
    font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
    opacity: 0.75;
  }

  .more-sections {
    margin-top: 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .more-section {
    border: none;
  }

  .more-section summary {
    cursor: pointer;
    font-size: 1.15rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 700;
    color: #ffffff;
    padding: 0.3rem 0;
    list-style: none;
    transition: color 0.2s;
    user-select: none;
  }

  .more-section summary::-webkit-details-marker {
    display: none;
  }

  .more-section summary::before {
    content: '+ ';
    font-family: monospace;
    font-size: 0.95rem;
  }

  .more-section[open] > summary::before {
    content: '- ';
  }

  .more-section summary:hover {
    color: var(--accent);
  }

  .section-body {
    font-size: 1.00rem;
    font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
    color: #ffffff;
    line-height: 1.6;
    padding: 0.3rem 0 0.6rem 1.2rem;
    max-width: 440px;
  }

  .bio-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .link-tag {
    font-size: 0.8rem;
    opacity: 0.6;
    font-family: monospace;
  }

  .contact-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .contact-icon {
    width: 1em;
    height: 1em;
    vertical-align: middle;
  }

  .more-link {
    color: #ffffff;
    font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
    transition: color 0.2s;
  }
  .more-link:hover {
    color: var(--accent);
  }

  /* ── Light mode text overrides ── */
  :global([data-theme="light"]) .hero-title {
    color: #2a1a10;
    text-shadow: 0 2px 40px rgba(180, 140, 80, 0.3);
  }
  :global([data-theme="light"]) .home-link {
    color: #2a1a10;
  }
  :global([data-theme="light"]) .home-link:hover {
    color: var(--accent);
  }
  :global([data-theme="light"]) .link-sep {
    color: rgba(42, 26, 16, 0.35);
  }
  :global([data-theme="light"]) .hero-subtitle {
    color: #3a2a18;
  }
  :global([data-theme="light"]) .more-section summary {
    color: #2a1a10;
  }
  :global([data-theme="light"]) .more-section summary:hover {
    color: var(--accent);
  }
  :global([data-theme="light"]) .section-body {
    color: #3a2a18;
  }
  :global([data-theme="light"]) .more-link {
    color: #5a4020;
  }
  :global([data-theme="light"]) .more-link:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .home-overlay {
      padding: 0 1.5rem;
    }
  }
</style>
